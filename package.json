{
  "scripts": {
    "build:css": "tailwindcss -i src/input.css -o vendor/tailwind.css --minify",
    "build:vendor": "cp node_modules/pdf-lib/dist/pdf-lib.min.js vendor/pdf-lib.min.js && cp node_modules/file-saver/dist/FileSaver.min.js vendor/FileSaver.min.js",
    "build": "npm run build:css && npm run build:vendor"
  },
  "dependencies": {
    "file-saver": "^2.0.5",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "fs-extra": "^11.3.2",
    "pdf-lib": "^1.17.1"
  }
}
